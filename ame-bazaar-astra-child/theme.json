{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "color": {
      "custom": false,
      "defaultPalette": false,
      "palette": [
        {
          "slug": "navy",
          "color": "#002347",
          "name": "Navy"
        },
        {
          "slug": "gold",
          "color": "#d4af37",
          "name": "Gold"
        },
        {
          "slug": "cream",
          "color": "#f8f7f4",
          "name": "Cream"
        },
        {
          "slug": "white",
          "color": "#ffffff",
          "name": "White"
        },
        {
          "slug": "slate",
          "color": "#334155",
          "name": "Slate"
        },
        {
          "slug": "charcoal",
          "color": "#1f2937",
          "name": "Charcoal"
        },
        {
          "slug": "border",
          "color": "#dbe2ea",
          "name": "Border"
        }
      ]
    },
    "spacing": {
      "customSpacingSize": false,
      "spacingSizes": [
        {
          "slug": "xs",
          "size": "0.5rem",
          "name": "XS"
        },
        {
          "slug": "sm",
          "size": "1rem",
          "name": "SM"
        },
        {
          "slug": "md",
          "size": "1.5rem",
          "name": "MD"
        },
        {
          "slug": "lg",
          "size": "2.5rem",
          "name": "LG"
        },
        {
          "slug": "xl",
          "size": "4rem",
          "name": "XL"
        }
      ]
    },
    "typography": {
      "customFontSize": false,
      "fontFamilies": [
        {
          "slug": "body",
          "name": "Body",
          "fontFamily": "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
        },
        {
          "slug": "heading",
          "name": "Heading",
          "fontFamily": "Georgia, 'Times New Roman', serif"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "#ffffff",
      "text": "#1f2937"
    },
    "typography": {
      "fontFamily": "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
    }
  }
}
